@model GestorSolicitudesTIC.Models.Usuario
@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="page-header">
    <h1>Nuevo Usuario</h1>
    <a asp-action="Index" class="btn-somex-out">← Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">👤 Datos del usuario</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert-err mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre completo <span class="text-danger">*</span></label>
                        <input asp-for="Nombre" class="form-control" maxlength="100" required />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Area" class="form-label">Área / Departamento <span class="text-danger">*</span></label>
                        <input asp-for="Area" class="form-control" maxlength="80" required />
                        <span asp-validation-for="Area" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Correo" class="form-label">Correo electrónico <span class="text-danger">*</span></label>
                        <input asp-for="Correo" type="email" class="form-control" required />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light rounded-pill">Cancelar</a>
                        <button type="submit" class="btn-somex">Crear usuario</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
