@model IEnumerable<GestorSolicitudesTIC.Models.Analista>
@{
    ViewData["Title"] = "Analistas TIC";
}

<div class="page-header">
    <h1>Analistas TIC</h1>
    <a asp-action="Create" class="btn-somex">+ Nuevo analista</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-somex table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Especialidad</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="text-muted small">@a.AnalistaId</td>
                        <td class="fw-semibold">@a.Nombre</td>
                        <td>
                            <span class="badge rounded-pill" style="background:#E8F5E9;color:#166534">@a.Especialidad</span>
                        </td>
                        <td class="text-muted small">@a.Correo</td>
                        <td>
                            @if (a.Activo)
                            {
                                <span class="badge rounded-pill badge-resuelta">Activo</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill badge-cerrada">Inactivo</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Edit" asp-route-id="@a.AnalistaId"
                                   class="btn btn-sm btn-outline-secondary rounded-pill" style="font-size:.75rem">Editar</a>
                                @if (a.Activo)
                                {
                                    <button onclick="confirmarEliminar('/Analistas/Delete/@a.AnalistaId','@Html.Raw(a.Nombre.Replace("'","\\\'"))')"
                                            class="btn btn-sm btn-outline-danger rounded-pill" style="font-size:.75rem">Desactivar</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay analistas registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
